# Qwen API key (get from https://dashscope.aliyun.com)
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx

# Qwen model via their API (no local vLLM needed if using cloud)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# OR if running vLLM locally on AMD ROCm GPU:
# QWEN_BASE_URL=http://localhost:8000/v1
# QWEN_MODEL=Qwen/Qwen2.5-7B-Instruct

# LangSmith (optional but recommended for hackathon demo)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=complaint-router

# MCP servers (optional — stub logging used if not set)
# SLACK_BOT_TOKEN=xoxb-...
# JIRA_URL=https://yourco.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=...
# PAGERDUTY_API_KEY=...
